---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const h2s = headings.filter(h => h.depth === 2);
const romanNumerals = ['I','II','III','IV','V','VI','VII','VIII'];
---
{h2s.length > 0 && (
  <div class="toc">
    <span class="toc__label">In this entry</span>
    <ul class="toc__list">
      {h2s.map((h, i) => (
        <li>
          <a href={`#${h.slug}`}>
            <span class="n">{romanNumerals[i] ?? String(i + 1)}</span>
            <span>{h.text.replace(/^[IVX]+\.\s*/, '')}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
